# Copy this file to .env and fill in real values.
# NEVER commit .env to version control. (CONF-1)

# Supabase PostgreSQL connection string (DB-1, CONF-1)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://app_user:CHANGE_ME@db.YOURPROJECT.supabase.co:5432/postgres

# Flask session signing key — generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
# Must be long, random, and secret. (Session layer, CONF-1)
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING

# Google reCAPTCHA v3 keys — get from https://www.google.com/recaptcha/admin (BOT-1, CONF-1)
RECAPTCHA_SITE_KEY=CHANGE_ME
RECAPTCHA_SECRET_KEY=CHANGE_ME

# Set to "production" on Render. Controls DEBUG mode. (ERR-1)
FLASK_ENV=production

